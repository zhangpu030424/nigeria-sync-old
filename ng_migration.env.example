# 复制为 ng_migration.env 并填写真实密码（勿提交 git）
# cp ng_migration.env.example ng_migration.env

# 源库（ng_loan_market / ng_loan_core）
SOURCE_HOST=10.52.139.200
SOURCE_PORT=3306
SOURCE_USER=root
SOURCE_PASSWORD=4-3kM^B0$I2s

# 目标库（生产 ng）
TARGET_HOST=101.47.15.219
TARGET_PORT=8001
TARGET_USER=ng-export
TARGET_PASSWORD=babzubfvkv6y43xbA
TARGET_DB=ng

# 分批参数（已调优：较小 USER_BATCH + 较大 INSERT_BATCH + 并行读源库）
MAX_USER_ID=9153604
MAX_APP_ID=
USER_BATCH=20000
USER_INSERT_BATCH=20000
APP_BATCH=100000
APP_INSERT_BATCH=10000
ID_MAPPING_INSERT_BATCH=25000
APP_WORKER_BALANCE=count
WORKERS=10
APP_WORKERS=8
LOOKUP_PARALLEL=4
LUP_PAIR_CHUNK=400
MAX_WORKER_SLOTS=64
PROGRESS_SAVE_EVERY=3

# full/user 启动前清理遗留 dt_mig_* 并重置进度（默认开启）
DROP_MAT_ON_START=1
DEADLOCK_MAX_RETRIES=8
INSERT_ROW_RETRIES=3

# 进度文件（断点续跑）
PROGRESS_FILE=/tmp/ng_mig_progress.env

# 性能日志（可选：同时写文件；每 N 批打印累计汇总）
LOG_FILE=/tmp/ng_mig_perf.log
LOG_EVERY=20

# 并行 worker 起始 id（多终端时各设不同 LO/HI）
LO=
HI=

# VT 敏感字段：从源库 vt_token_cache 查 token（status=1），未命中则跳过
VT_TOKEN_ENABLE=1
VT_TOKEN_CHUNK=2000
VT_TOKEN_DB=ng_loan_market
# 启动时一次性预加载 VT 字典到内存（批内 O(1) 查，显著缩短每批耗时）
VT_PRELOAD=1
